{
  "manifest_version": 3,
  "name": "天音 AI 创作助手",
  "version": "1.1.0",
  "description": "网易云天音 AI 写歌创作助手 — 以 Diff 审核模式辅助歌词、歌曲想法和歌曲名称的创作",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://music.163.com/st/tianyin/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://music.163.com/st/tianyin/*"],
      "js": [
        "shared/constants.js",
        "shared/utils.js",
        "core/diff.js",
        "core/prompt-templates.js",
        "core/deepseek-client.js",
        "content/codemirror-host.js",
        "content/selection-bridge.js",
        "content/diff-overlay.js",
        "content/injector.js",
        "content/sidebar-host.js"
      ],
      "css": [
        "sidebar/styles/sidebar.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar/index.html",
        "sidebar/*",
        "lib/codemirror/codemirror-bundle.js"
      ],
      "matches": ["https://music.163.com/*"]
    }
  ]
}
